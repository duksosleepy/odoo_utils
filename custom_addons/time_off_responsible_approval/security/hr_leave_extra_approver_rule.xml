<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- extra_approver_user_ids on hr.leave is defined here, so the ir.rule lives here too -->
    <data>
        <!--
            Odoo grants Time Off Officers read/write access to every request.
            Keep that role behavior intact: approvers explicitly assigned the
            "Officer: Manage all requests" role must still be able to open the
            requests they manage from notifications, lists, and direct links.

            Time Off Responsible and extra-approver access stays narrower for
            users without the officer role: own requests through Odoo's base
            employee rules, or requests where they can currently perform an
            approval action. Explicit handover-recipient and read-only-notifier
            rules remain separate, narrowly scoped workflow grants.

            Time Off Administrators keep unrestricted access through
            hr_holidays.hr_leave_rule_manager.
        -->
        <record id="hr_holidays.hr_leave_rule_responsible_read" model="ir.rule">
            <field name="domain_force">
                [('approval_actionable_user_ids', 'in', [user.id])]
            </field>
        </record>

        <record id="hr_holidays.hr_leave_rule_responsible_update" model="ir.rule">
            <field name="domain_force">
                [('approval_actionable_user_ids', 'in', [user.id])]
            </field>
        </record>

        <record id="hr_holidays.hr_leave_rule_user_read" model="ir.rule">
            <field name="domain_force">
                [(1, '=', 1)]
            </field>
        </record>

        <record id="hr_holidays.hr_leave_rule_officer_update" model="ir.rule">
            <field name="domain_force">
                [
                    '|',
                        '&amp;',
                            ('employee_id.user_id', '=', user.id),
                            ('state', '!=', 'validate'),
                        '|',
                            ('employee_id.user_id', '!=', user.id),
                            ('employee_id.user_id', '=', False)
                ]
            </field>
        </record>

        <record id="hr_leave_rule_extra_approver" model="ir.rule">
            <field name="name">Time Off: Extra Approvers access</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">
                [
                    ('approval_actionable_user_ids', 'in', [user.id]),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="hr_leave_rule_special_readonly_notifier_read" model="ir.rule">
            <field name="name">Time Off: Special read-only notifier access</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave"/>
            <field name="domain_force">
                [
                    ('employee_id', '!=', False),
                    ('state', 'in', ['confirm', 'validate1', 'validate', 'refuse']),
                    ('special_readonly_notifier_user_ids', 'in', [user.id]),
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
