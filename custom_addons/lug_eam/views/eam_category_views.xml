<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_eam_category_list" model="ir.ui.view">
        <field name="name">eam.category.list</field>
        <field name="model">maintenance.equipment.category</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Nhóm tài sản">
                <field name="code"/>
                <field name="complete_name"/>
                <field name="parent_id"/>
                <field name="maintenance_cycle_month"/>
                <field name="equipment_count"/>
            </list>
        </field>
    </record>

    <record id="view_eam_category_form" model="ir.ui.view">
        <field name="name">eam.category.form</field>
        <field name="model">maintenance.equipment.category</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Nhóm tài sản">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="VD: Máy lạnh"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="VD: CAT001"/>
                            <field name="parent_id"/>
                            <field name="technician_user_id"/>
                        </group>
                        <group>
                            <field name="require_qr"/>
                            <field name="require_warranty"/>
                            <field name="maintenance_cycle_month"/>
                            <field name="inspection_cycle_month"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_eam_category_search" model="ir.ui.view">
        <field name="name">eam.category.search</field>
        <field name="model">maintenance.equipment.category</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
            </search>
        </field>
    </record>

    <record id="action_eam_category" model="ir.actions.act_window">
        <field name="name">Nhóm tài sản</field>
        <field name="res_model">maintenance.equipment.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_eam_category_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'sequence': 1, 'view_mode': 'list', 'view_id': ref('view_eam_category_list')}),
            (0, 0, {'sequence': 2, 'view_mode': 'form', 'view_id': ref('view_eam_category_form')})]"/>
    </record>
</odoo>
