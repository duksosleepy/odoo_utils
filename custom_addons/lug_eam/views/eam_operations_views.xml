<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ BẢO TRÌ ============ -->
    <record id="action_eam_maint_calendar" model="ir.actions.act_window">
        <field name="name">Lịch bảo trì</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">calendar,list,kanban,form</field>
    </record>

    <record id="action_eam_maint_request" model="ir.actions.act_window">
        <field name="name">Phiếu bảo trì</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">kanban,list,form,calendar,pivot,graph</field>
    </record>

    <record id="action_eam_repair" model="ir.actions.act_window">
        <field name="name">Sửa chữa</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="domain">[('maintenance_type', '=', 'corrective')]</field>
        <field name="context">{'default_maintenance_type': 'corrective'}</field>
    </record>

    <!-- ============ NHÀ CUNG CẤP ============ -->
    <record id="action_eam_supplier" model="ir.actions.act_window">
        <field name="name">Nhà cung cấp</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_company', '=', True)]</field>
        <field name="context">{'default_is_company': True}</field>
    </record>

    <!-- ============ BỘ PHẬN (Mã bộ phận) ============ -->
    <record id="view_eam_store_code_list" model="ir.ui.view">
        <field name="name">eam.store.code.list</field>
        <field name="model">hr.store.code</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Bộ phận" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="mien"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_eam_store_code_search" model="ir.ui.view">
        <field name="name">eam.store.code.search</field>
        <field name="model">hr.store.code</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <filter name="group_mien" string="Miền" context="{'group_by': 'mien'}"/>
            </search>
        </field>
    </record>

    <record id="action_eam_store_code" model="ir.actions.act_window">
        <field name="name">Bộ phận</field>
        <field name="res_model">hr.store.code</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_eam_store_code_search"/>
    </record>
</odoo>
