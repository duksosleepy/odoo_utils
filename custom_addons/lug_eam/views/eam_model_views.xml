<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_eam_model_list" model="ir.ui.view">
        <field name="name">eam.model.list</field>
        <field name="model">eam.model</field>
        <field name="arch" type="xml">
            <list string="Model">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="brand_id"/>
                <field name="default_warranty_month"/>
                <field name="equipment_count"/>
            </list>
        </field>
    </record>

    <record id="view_eam_model_form" model="ir.ui.view">
        <field name="name">eam.model.form</field>
        <field name="model">eam.model</field>
        <field name="arch" type="xml">
            <form string="Model">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="VD: FTKB25"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="VD: MDL00001"/>
                            <field name="category_id"/>
                            <field name="brand_id"/>
                        </group>
                        <group>
                            <field name="default_warranty_month"/>
                            <field name="default_cost"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thông số kỹ thuật">
                            <field name="specification" placeholder="Công suất, CPU, RAM..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_eam_model_search" model="ir.ui.view">
        <field name="name">eam.model.search</field>
        <field name="model">eam.model</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="brand_id"/>
                <group>
                    <filter name="group_category" string="Nhóm tài sản" context="{'group_by': 'category_id'}"/>
                    <filter name="group_brand" string="Thương hiệu" context="{'group_by': 'brand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_eam_model" model="ir.actions.act_window">
        <field name="name">Model</field>
        <field name="res_model">eam.model</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
