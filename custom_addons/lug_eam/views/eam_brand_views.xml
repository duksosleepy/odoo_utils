<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_eam_brand_list" model="ir.ui.view">
        <field name="name">eam.brand.list</field>
        <field name="model">eam.brand</field>
        <field name="arch" type="xml">
            <list string="Thương hiệu">
                <field name="code"/>
                <field name="name"/>
                <field name="country_id"/>
                <field name="model_count"/>
            </list>
        </field>
    </record>

    <record id="view_eam_brand_form" model="ir.ui.view">
        <field name="name">eam.brand.form</field>
        <field name="model">eam.brand</field>
        <field name="arch" type="xml">
            <form string="Thương hiệu">
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="VD: Daikin"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="VD: BRD001"/>
                            <field name="country_id"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_eam_brand_search" model="ir.ui.view">
        <field name="name">eam.brand.search</field>
        <field name="model">eam.brand</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="country_id"/>
            </search>
        </field>
    </record>

    <record id="action_eam_brand" model="ir.actions.act_window">
        <field name="name">Thương hiệu</field>
        <field name="res_model">eam.brand</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
