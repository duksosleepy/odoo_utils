<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ TRANSACTION LIST / FORM ============ -->
    <record id="view_eam_transaction_list" model="ir.ui.view">
        <field name="name">eam.transaction.list</field>
        <field name="model">eam.transaction</field>
        <field name="arch" type="xml">
            <list string="Phiếu giao dịch">
                <field name="name"/>
                <field name="txn_type"/>
                <field name="date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'to_approve'"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'cancel'"/>
                <field name="warehouse_id" optional="show"/>
                <field name="dest_location_id" optional="show"/>
                <field name="line_count"/>
                <field name="user_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_eam_transaction_form" model="ir.ui.view">
        <field name="name">eam.transaction.form</field>
        <field name="model">eam.transaction</field>
        <field name="arch" type="xml">
            <form string="Phiếu giao dịch">
                <header>
                    <button name="action_submit" string="Gửi duyệt" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Duyệt" type="object"
                            class="btn-primary" invisible="state != 'to_approve'"
                            groups="lug_eam.group_eam_wh_manager,lug_eam.group_eam_asset_manager"/>
                    <button name="action_reset_draft" string="Về nháp" type="object"
                            invisible="state not in ('to_approve', 'cancel')"/>
                    <button name="action_cancel" string="Hủy" type="object"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_load_expected_assets" string="Nạp tài sản kỳ vọng"
                            type="object" invisible="txn_type != 'count' or state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,to_approve,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="txn_type" readonly="state != 'draft'"/>
                            <field name="date"/>
                            <field name="warehouse_id"/>
                            <field name="partner_id" invisible="txn_type != 'in'"/>
                        </group>
                        <group>
                            <field name="src_location_id"/>
                            <field name="dest_location_id"/>
                            <field name="department_id" invisible="txn_type not in ('out', 'transfer')"/>
                            <field name="owner_employee_id" invisible="txn_type not in ('out', 'transfer')"/>
                            <field name="amount_recovery" invisible="txn_type != 'disposal'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="reason" placeholder="Lý do / ghi chú"/>
                    <notebook>
                        <page string="Chi tiết tài sản">
                            <field name="line_ids" readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="asset_id"/>
                                    <field name="asset_code"/>
                                    <field name="from_location_id" optional="show"/>
                                    <field name="to_location_id" optional="show"/>
                                    <field name="counted" column_invisible="parent.txn_type != 'count'"/>
                                    <field name="discrepancy" column_invisible="parent.txn_type != 'count'"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_eam_transaction_search" model="ir.ui.view">
        <field name="name">eam.transaction.search</field>
        <field name="model">eam.transaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="txn_type"/>
                <filter name="f_draft" string="Nháp" domain="[('state', '=', 'draft')]"/>
                <filter name="f_approve" string="Chờ duyệt" domain="[('state', '=', 'to_approve')]"/>
                <filter name="f_done" string="Hoàn thành" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter name="group_type" string="Loại" context="{'group_by': 'txn_type'}"/>
                    <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_eam_txn_in" model="ir.actions.act_window">
        <field name="name">Nhập kho</field>
        <field name="res_model">eam.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('txn_type', '=', 'in')]</field>
        <field name="context">{'default_txn_type': 'in'}</field>
        <field name="search_view_id" ref="view_eam_transaction_search"/>
    </record>

    <record id="action_eam_txn_out" model="ir.actions.act_window">
        <field name="name">Xuất kho / Cấp phát</field>
        <field name="res_model">eam.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('txn_type', '=', 'out')]</field>
        <field name="context">{'default_txn_type': 'out'}</field>
        <field name="search_view_id" ref="view_eam_transaction_search"/>
    </record>

    <record id="action_eam_txn_transfer" model="ir.actions.act_window">
        <field name="name">Điều chuyển</field>
        <field name="res_model">eam.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('txn_type', '=', 'transfer')]</field>
        <field name="context">{'default_txn_type': 'transfer'}</field>
        <field name="search_view_id" ref="view_eam_transaction_search"/>
    </record>

    <record id="action_eam_txn_count" model="ir.actions.act_window">
        <field name="name">Kiểm kê</field>
        <field name="res_model">eam.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('txn_type', '=', 'count')]</field>
        <field name="context">{'default_txn_type': 'count'}</field>
        <field name="search_view_id" ref="view_eam_transaction_search"/>
    </record>

    <record id="action_eam_txn_disposal" model="ir.actions.act_window">
        <field name="name">Thanh lý</field>
        <field name="res_model">eam.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('txn_type', '=', 'disposal')]</field>
        <field name="context">{'default_txn_type': 'disposal'}</field>
        <field name="search_view_id" ref="view_eam_transaction_search"/>
    </record>

    <!-- ============ TRANSACTION LINE (history on asset) ============ -->
    <record id="view_eam_transaction_line_list" model="ir.ui.view">
        <field name="name">eam.transaction.line.list</field>
        <field name="model">eam.transaction.line</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="header_id"/>
                <field name="txn_type"/>
                <field name="from_state"/>
                <field name="to_state"/>
                <field name="from_location_id"/>
                <field name="to_location_id"/>
            </list>
        </field>
    </record>
</odoo>
