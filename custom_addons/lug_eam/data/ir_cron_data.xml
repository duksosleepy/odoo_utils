<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="cron_eam_preventive" model="ir.cron">
        <field name="name">EAM: Sinh phiếu bảo trì phòng ngừa</field>
        <field name="model_id" ref="maintenance.model_maintenance_request"/>
        <field name="state">code</field>
        <field name="code">model._cron_eam_preventive_maintenance()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_eam_warranty" model="ir.cron">
        <field name="name">EAM: Cảnh báo bảo hành</field>
        <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="state">code</field>
        <field name="code">model._cron_eam_warranty_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_eam_inspection" model="ir.cron">
        <field name="name">EAM: Sinh phiếu kiểm tra</field>
        <field name="model_id" ref="model_eam_inspection"/>
        <field name="state">code</field>
        <field name="code">model._cron_eam_inspection_due()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_eam_sla" model="ir.cron">
        <field name="name">EAM: Kiểm tra SLA bảo trì</field>
        <field name="model_id" ref="maintenance.model_maintenance_request"/>
        <field name="state">code</field>
        <field name="code">model._cron_eam_sla_check()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_eam_kpi" model="ir.cron">
        <field name="name">EAM: Snapshot KPI hằng đêm</field>
        <field name="model_id" ref="model_eam_kpi_snapshot"/>
        <field name="state">code</field>
        <field name="code">model._cron_eam_kpi_snapshot()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
