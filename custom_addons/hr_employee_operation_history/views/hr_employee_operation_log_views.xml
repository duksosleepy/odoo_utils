<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_operation_log_view_list" model="ir.ui.view">
        <field name="name">hr.employee.operation.log.list</field>
        <field name="model">hr.employee.operation.log</field>
        <field name="arch" type="xml">
            <list string="Operation History"
                  create="false"
                  edit="false"
                  delete="false"
                  class="o_hr_employee_operation_history_list"
                  default_order="operation_date desc">
                <field name="operation_date"
                       widget="datetime"
                       string="Operation Date"
                       width="145px"/>
                <field name="operation"
                       string="Operation"
                       width="95px"/>
                <field name="user_id"
                       widget="many2one_avatar_user"
                       string="User"
                       width="155px"/>
                <field name="employee_name"
                       string="Employee"
                       width="160px"/>
                <field name="change_summary"
                       string="Change Summary"/>
            </list>
        </field>
    </record>

    <record id="hr_employee_operation_log_view_form" model="ir.ui.view">
        <field name="name">hr.employee.operation.log.form</field>
        <field name="model">hr.employee.operation.log</field>
        <field name="arch" type="xml">
            <form string="Operation History" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="employee_name"/>
                            <field name="operation"/>
                        </group>
                        <group>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="operation_date" widget="datetime"/>
                            <field name="change_count"/>
                        </group>
                    </group>
                    <group string="Change Summary">
                        <field name="change_summary" nolabel="1" colspan="2"/>
                    </group>
                    <separator string="Change Details"/>
                    <field name="change_line_ids"
                           readonly="1"
                           class="o_hr_employee_operation_history_lines"
                           nolabel="1">
                        <list create="false" edit="false" delete="false">
                            <field name="field_label"
                                   string="Field"
                                   width="180px"/>
                            <field name="old_value"
                                   string="Old Value"
                                   width="260px"/>
                            <field name="new_value"
                                   string="New Value"
                                   width="260px"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_employee_operation_log_view_search" model="ir.ui.view">
        <field name="name">hr.employee.operation.log.search</field>
        <field name="model">hr.employee.operation.log</field>
        <field name="arch" type="xml">
            <search string="Operation History">
                <field name="employee_name"/>
                <field name="user_id"/>
                <field name="operation"/>
                <field name="change_summary"/>
                <filter string="Create" name="operation_create" domain="[('operation', '=', 'create')]"/>
                <filter string="Update" name="operation_write" domain="[('operation', '=', 'write')]"/>
                <filter string="Delete" name="operation_unlink" domain="[('operation', '=', 'unlink')]"/>
                <separator/>
                <filter string="Employee" name="group_employee" domain="[]" context="{'group_by': 'employee_id'}"/>
                <filter string="User" name="group_user" domain="[]" context="{'group_by': 'user_id'}"/>
                <filter string="Operation" name="group_operation" domain="[]" context="{'group_by': 'operation'}"/>
                <filter string="Date" name="group_date" domain="[]" context="{'group_by': 'operation_date:day'}"/>
            </search>
        </field>
    </record>

    <record id="hr_employee_operation_log_action" model="ir.actions.act_window">
        <field name="name">Employee Operation History</field>
        <field name="res_model">hr.employee.operation.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_employee_operation_log_view_search"/>
    </record>
</odoo>
