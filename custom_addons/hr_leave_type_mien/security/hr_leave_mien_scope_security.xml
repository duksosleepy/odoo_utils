<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
    Permission "Phạm vi Ngày nghỉ" shown under Settings > Users > Nhân sự.
    Limits which Miền a user can see on leave requests (hr.leave) and on linked
    approval activities. When "Văn Phòng" or "Cửa Hàng" is selected, the filter
    applies even for Time Off administrators. Only users without this scope keep
    unrestricted visibility through their existing Time Off role.
    -->
    <record id="res_groups_privilege_leave_mien_scope" model="res.groups.privilege">
        <field name="name">Phạm vi Ngày nghỉ</field>
        <field name="sequence">17</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="description">Giới hạn Miền mà người dùng được xem trên danh sách đơn nghỉ phép và hoạt động phê duyệt liên quan.</field>
        <field name="placeholder">Không</field>
    </record>

    <record id="group_leave_mien_vp" model="res.groups">
        <field name="name">Văn Phòng</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_leave_mien_scope"/>
        <field name="comment">Người dùng chỉ thấy đơn nghỉ phép thuộc Miền VP.</field>
    </record>

    <record id="group_leave_mien_store" model="res.groups">
        <field name="name">Cửa Hàng</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_leave_mien_scope"/>
        <field name="comment">Người dùng chỉ thấy đơn nghỉ phép thuộc Miền Bắc, Nam và ĐTT.</field>
    </record>

    <!--
    Global record rule on hr.leave: AND-ed with every other leave rule.
    When VP / Cửa Hàng is selected, filter applies to everyone (including
    Time Off administrators). Without a scope, this rule does not restrict.
    -->
    <record id="hr_leave_mien_scope_rule" model="ir.rule">
        <field name="name">Đơn nghỉ phép: lọc theo Phạm vi Miền</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="domain_force">(['|', ('employee_id.user_id', '=', user.id), ('employee_leave_mien', 'in', ['VP', 'Bắc', 'Nam', 'ĐTT'])] if (user.has_group('hr_leave_type_mien.group_leave_mien_vp') and user.has_group('hr_leave_type_mien.group_leave_mien_store')) else (['|', ('employee_id.user_id', '=', user.id), ('employee_leave_mien', '=', 'VP')] if user.has_group('hr_leave_type_mien.group_leave_mien_vp') else (['|', ('employee_id.user_id', '=', user.id), ('employee_leave_mien', 'in', ['Bắc', 'Nam', 'ĐTT'])] if user.has_group('hr_leave_type_mien.group_leave_mien_store') else [(1, '=', 1)])))</field>
    </record>
</odoo>
