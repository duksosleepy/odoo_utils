<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_leave_mien_config_list" model="ir.ui.view">
        <field name="name">hr.leave.mien.config.list</field>
        <field name="model">hr.leave.mien.config</field>
        <field name="arch" type="xml">
            <list string="Phân chia ngày nghỉ" default_order="sequence, mien">
                <field name="sequence" widget="handle" column_invisible="True"/>
                <field name="display_name" string="Miền"/>
            </list>
        </field>
    </record>

    <record id="view_hr_leave_mien_config_search" model="ir.ui.view">
        <field name="name">hr.leave.mien.config.search</field>
        <field name="model">hr.leave.mien.config</field>
        <field name="arch" type="xml">
            <search string="Phân chia ngày nghỉ">
                <field name="mien"/>
                <separator/>
                <filter string="Bắc" name="mien_bac" domain="[('mien', '=', 'Bắc')]"/>
                <filter string="Nam" name="mien_nam" domain="[('mien', '=', 'Nam')]"/>
                <filter string="ĐTT" name="mien_dtt" domain="[('mien', '=', 'ĐTT')]"/>
                <filter string="VP" name="mien_vp" domain="[('mien', '=', 'VP')]"/>
            </search>
        </field>
    </record>

    <record id="view_hr_leave_mien_config_form" model="ir.ui.view">
        <field name="name">hr.leave.mien.config.form</field>
        <field name="model">hr.leave.mien.config</field>
        <field name="arch" type="xml">
            <form string="Phân chia ngày nghỉ">
                <sheet>
                    <div class="oe_title">
                        <label for="mien"/>
                        <h1>
                            <field name="mien" placeholder="Chọn Miền"/>
                        </h1>
                    </div>
                    <group string="Loại ngày nghỉ áp dụng">
                        <field name="line_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="leave_type_id" options="{'no_create': True}" context="{'skip_mien_leave_type_filter': True}"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_leave_mien_config" model="ir.actions.act_window">
        <field name="name">Phân chia ngày nghỉ</field>
        <field name="res_model">hr.leave.mien.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_leave_mien_config_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo cấu hình cho từng Miền
            </p>
            <p>
                Mỗi Miền (Bắc, Nam, ĐTT, VP) chỉ cần <strong>một bản ghi</strong>.
                Thêm nhiều dòng loại ngày nghỉ trong bảng bên dưới.
                Nhân viên thuộc Miền đó chỉ thấy các loại đã chọn khi tạo đơn Time Off.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_hr_leave_type_mien_configuration"
        name="Phân chia ngày nghỉ"
        parent="hr_holidays.menu_hr_holidays_configuration"
        action="action_hr_leave_mien_config"
        groups="hr_holidays.group_hr_holidays_manager"
        sequence="2"/>

</odoo>
