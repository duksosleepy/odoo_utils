<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_holiday_status_form_refuse_notifier" model="ir.ui.view">
        <field name="name">hr.leave.type.form.refuse.notifier</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='configuration']" position="after">
                <group name="notify" string="Notify">
                    <field name="refuse_notify_employee_id"
                           placeholder="Select employee to notify on refuse"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
