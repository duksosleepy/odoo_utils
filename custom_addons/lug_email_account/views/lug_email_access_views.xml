<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lug_email_access_list" model="ir.ui.view">
        <field name="name">lug.email.access.list</field>
        <field name="model">lug.email.access</field>
        <field name="arch" type="xml">
            <list string="Phân quyền xem email">
                <field name="user_id"/>
                <field name="group_id" string="Nhóm quyền"/>
                <field name="active" string="Trạng thái" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_lug_email_access_form" model="ir.ui.view">
        <field name="name">lug.email.access.form</field>
        <field name="model">lug.email.access</field>
        <field name="arch" type="xml">
            <form string="Phân quyền xem email">
                <header>
                    <button name="action_reload_departments"
                            type="object"
                            string="Tải lại phòng ban"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="allowed_group_ids" invisible="1"/>
                            <field name="user_id" options="{'no_create': True}"/>
                            <field name="group_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="active" string="Trạng thái" widget="boolean_toggle"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Phạm vi xem" name="scope">
                            <field name="line_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="department_id" readonly="1" force_save="1"/>
                                    <field name="can_view" string="Được xem" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lug_email_access_search" model="ir.ui.view">
        <field name="name">lug.email.access.search</field>
        <field name="model">lug.email.access</field>
        <field name="arch" type="xml">
            <search string="Phân quyền xem email">
                <field name="user_id"/>
                <field name="group_id"/>
                <filter name="filter_active" string="Hoạt động" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Ngưng hoạt động" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_lug_email_access" model="ir.actions.act_window">
        <field name="name">Phân quyền xem Email</field>
        <field name="res_model">lug.email.access</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lug_email_access_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có phân quyền email
            </p>
            <p>
                Cấu hình nhóm quyền và phạm vi phòng ban mà từng user được xem email.
            </p>
        </field>
    </record>
</odoo>
