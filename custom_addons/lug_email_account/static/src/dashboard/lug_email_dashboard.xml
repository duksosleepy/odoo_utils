<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lug_email_account.LugEmailDashboard">
        <div class="o_lug_email_dashboard o_action">
            <div class="o_lug_email_dashboard_header">
                <div>
                    <h2>Dashboard Email</h2>
                    <p class="o_lug_email_dashboard_subtitle">
                        Tổng quan tài khoản email theo phòng ban và xu hướng tạo mới.
                    </p>
                </div>
                <button type="button" class="btn btn-primary btn-sm" t-on-click="openAllEmails">
                    <i class="fa fa-list me-1"/> Danh sách email
                </button>
            </div>

            <div class="o_lug_email_dashboard_scroll">
            <t t-if="state.loading">
                <div class="text-center p-5">
                    <i class="fa fa-spinner fa-spin fa-2x"/>
                </div>
            </t>
            <t t-else="">
                <div class="o_lug_email_kpi_row">
                    <div class="o_lug_email_kpi_card o_lug_email_kpi_card--total">
                        <div class="o_lug_email_kpi_icon">
                            <i class="fa fa-envelope"/>
                        </div>
                        <div>
                            <div class="o_lug_email_kpi_value" t-esc="state.data.total || 0"/>
                            <div class="o_lug_email_kpi_label">Tổng Email</div>
                        </div>
                    </div>
                    <div class="o_lug_email_kpi_card o_lug_email_kpi_card--status o_lug_email_kpi_card--active">
                        <div class="o_lug_email_status_chart_wrap">
                            <canvas t-ref="activeChart"/>
                        </div>
                        <div>
                            <div class="o_lug_email_kpi_value" t-esc="state.data.kpi.active || 0"/>
                            <div class="o_lug_email_kpi_label">Đang hoạt động</div>
                            <div class="o_lug_email_kpi_percent">
                                <t t-esc="state.data.kpi.active_percent || 0"/>%
                            </div>
                        </div>
                    </div>
                    <div class="o_lug_email_kpi_card o_lug_email_kpi_card--status o_lug_email_kpi_card--cancel">
                        <div class="o_lug_email_status_chart_wrap">
                            <canvas t-ref="cancelChart"/>
                        </div>
                        <div>
                            <div class="o_lug_email_kpi_value" t-esc="state.data.kpi.cancel || 0"/>
                            <div class="o_lug_email_kpi_label">Đang hủy</div>
                            <div class="o_lug_email_kpi_percent">
                                <t t-esc="state.data.kpi.cancel_percent || 0"/>%
                            </div>
                        </div>
                    </div>
                    <div class="o_lug_email_kpi_card o_lug_email_kpi_card--status o_lug_email_kpi_card--lock">
                        <div class="o_lug_email_status_chart_wrap">
                            <canvas t-ref="lockChart"/>
                        </div>
                        <div>
                            <div class="o_lug_email_kpi_value" t-esc="state.data.kpi.lock || 0"/>
                            <div class="o_lug_email_kpi_label">Tạm dừng</div>
                            <div class="o_lug_email_kpi_percent">
                                <t t-esc="state.data.kpi.lock_percent || 0"/>%
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-lg-6">
                        <div class="o_lug_email_panel o_lug_email_panel--department">
                            <div class="o_lug_email_department_header">
                                <h5>
                                    <i class="fa fa-envelope-o me-2"/>
                                    Email theo phòng ban
                                </h5>
                                <div class="o_lug_email_department_summary">
                                    <span>
                                        Tổng:
                                        <strong t-esc="departmentSummary.total"/>
                                    </span>
                                    <span class="o_lug_email_department_divider">|</span>
                                    <span>
                                        Đã phân loại:
                                        <strong t-esc="departmentSummary.classified_count"/>
                                    </span>
                                    <span class="o_lug_email_department_divider">|</span>
                                    <span>
                                        Chưa phân loại:
                                        <strong t-esc="departmentSummary.uncategorized_count"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_lug_email_department_layout">
                                <div class="o_lug_email_chart_wrap o_lug_email_chart_wrap--donut">
                                    <canvas t-ref="departmentChart"/>
                                    <div class="o_lug_email_donut_center">
                                        <strong t-esc="departmentSummary.total"/>
                                        <span>Email</span>
                                    </div>
                                </div>
                                <div class="o_lug_email_department_table_wrap">
                                    <table class="table table-sm mb-0 o_lug_email_department_table">
                                        <colgroup>
                                            <col class="o_col_department"/>
                                            <col class="o_col_sl"/>
                                            <col class="o_col_rate"/>
                                        </colgroup>
                                        <thead>
                                            <tr>
                                                <th class="o_th_department">Phòng ban</th>
                                                <th class="o_th_sl">SL</th>
                                                <th class="o_th_rate">Tỷ lệ</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="!departmentSummary.legend_rows.length">
                                                <tr>
                                                    <td colspan="3" class="text-muted">
                                                        Chưa có phòng ban đã phân loại
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-foreach="departmentSummary.legend_rows" t-as="row" t-key="row.label">
                                                <tr>
                                                    <td class="o_td_department">
                                                        <span class="o_lug_email_legend_dot me-2"
                                                              t-attf-style="background-color: {{ row.color }}"/>
                                                        <span class="o_department_name" t-esc="row.label"/>
                                                    </td>
                                                    <td class="o_td_sl" t-esc="row.count"/>
                                                    <td class="o_td_rate">
                                                        <t t-esc="row.share_percent"/>%
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="o_lug_email_panel o_lug_email_panel--department o_lug_email_panel--region">
                            <div class="o_lug_email_department_header">
                                <h5>
                                    <i class="fa fa-map-marker me-2"/>
                                    Email theo miền
                                </h5>
                                <div class="o_lug_email_department_summary">
                                    <span>
                                        Tổng:
                                        <strong t-esc="regionSummary.total"/>
                                    </span>
                                    <span class="o_lug_email_department_divider">|</span>
                                    <span>
                                        Đã phân loại:
                                        <strong t-esc="regionSummary.classified_count"/>
                                    </span>
                                    <span class="o_lug_email_department_divider">|</span>
                                    <span>
                                        Chưa phân loại:
                                        <strong t-esc="regionSummary.uncategorized_count"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_lug_email_department_layout">
                                <div class="o_lug_email_chart_wrap o_lug_email_chart_wrap--donut">
                                    <canvas t-ref="regionChart"/>
                                    <div class="o_lug_email_donut_center">
                                        <strong t-esc="regionSummary.total"/>
                                        <span>Email</span>
                                    </div>
                                </div>
                                <div class="o_lug_email_department_table_wrap">
                                    <table class="table table-sm mb-0 o_lug_email_department_table">
                                        <colgroup>
                                            <col class="o_col_department"/>
                                            <col class="o_col_sl"/>
                                            <col class="o_col_rate"/>
                                        </colgroup>
                                        <thead>
                                            <tr>
                                                <th class="o_th_department">Miền</th>
                                                <th class="o_th_sl">SL</th>
                                                <th class="o_th_rate">Tỷ lệ</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="regionSummary.legend_rows" t-as="row" t-key="row.label">
                                                <tr>
                                                    <td class="o_td_department">
                                                        <span class="o_lug_email_legend_dot me-2"
                                                              t-attf-style="background-color: {{ row.color }}"/>
                                                        <span class="o_department_name" t-esc="row.label"/>
                                                    </td>
                                                    <td class="o_td_sl" t-esc="row.count"/>
                                                    <td class="o_td_rate">
                                                        <t t-esc="row.share_percent"/>%
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <div class="o_lug_email_panel">
                            <h5>Email tạo theo tháng</h5>
                            <p class="o_lug_email_panel_hint">Số lượng email được tạo mới trong 12 tháng gần nhất.</p>
                            <div class="o_lug_email_chart_wrap o_lug_email_chart_wrap--bar">
                                <canvas t-ref="monthChart"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="o_lug_email_panel mt-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h5 class="mb-0">Danh sách email mới</h5>
                            <p class="o_lug_email_panel_hint mb-0">10 email mới nhất trong hệ thống.</p>
                        </div>
                    </div>
                    <div class="o_lug_email_table_scroll table-responsive">
                        <table class="table table-sm table-hover mb-0 o_lug_email_recent_table">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Email</th>
                                    <th>Họ và tên NV</th>
                                    <th>Phòng ban</th>
                                    <th>Ngày tạo</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="!(state.data.recent_emails || []).length">
                                    <tr>
                                        <td colspan="6" class="text-muted">Chưa có dữ liệu email</td>
                                    </tr>
                                </t>
                                <t t-foreach="state.data.recent_emails || []" t-as="row" t-key="row.id">
                                    <tr class="o_lug_email_row_link" t-on-click="() => this.openEmail(row.id)">
                                        <td t-esc="row.stt"/>
                                        <td t-esc="row.email"/>
                                        <td t-esc="row.employee_name"/>
                                        <td t-esc="row.department"/>
                                        <td t-esc="row.date_created"/>
                                        <td t-esc="row.status"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
            </div>
        </div>
    </t>
</templates>
