<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_kho_form" model="ir.ui.view">
            <field name="name">hr.kho.form</field>
            <field name="model">hr.kho</field>
            <field name="arch" type="xml">
                <form string="Mã Kho">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_title">
                            <label for="code"/>
                            <h1>
                                <field name="code" placeholder="e.g. KHO-HN"/>
                            </h1>
                            <label for="name"/>
                            <h2>
                                <field name="name" placeholder="e.g. Kho Hà Nội"/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="mien"/>
                            </group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            </group>
                        </group>
                        <group string="Ghi chú">
                            <field name="note" nolabel="1" placeholder="Ghi chú nội bộ về mã kho..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_kho_list" model="ir.ui.view">
            <field name="name">hr.kho.list</field>
            <field name="model">hr.kho</field>
            <field name="arch" type="xml">
                <list string="Mã Kho" multi_edit="1">
                    <field name="active" column_invisible="True"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="mien"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <record id="view_hr_kho_search" model="ir.ui.view">
            <field name="name">hr.kho.search</field>
            <field name="model">hr.kho</field>
            <field name="arch" type="xml">
                <search string="Mã Kho">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="mien"/>
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <group>
                        <filter string="Miền" name="group_mien" context="{'group_by': 'mien'}"/>
                        <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="hr_kho_action" model="ir.actions.act_window">
            <field name="name">Mã Kho</field>
            <field name="res_model">hr.kho</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_kho_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo mã kho mới
                </p>
                <p>
                    Quản lý danh mục mã kho dùng trong cấu hình nhân sự.
                </p>
            </field>
        </record>
    </data>
</odoo>
