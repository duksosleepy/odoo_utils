<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_view_form_hrm_timeoff" model="ir.ui.view">
        <field name="name">hr.employee.form.hrm.timeoff</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='personal_information']" position="inside">
                <group string="Time off" groups="hr.group_hr_user">
                    <group>
                        <field name="phep_chuan"/>
                        <field name="tong_so_phep"/>
                        <field name="da_su_dung"/>
                        <field name="con_lai"/>
                        <field name="ngay_het_han"/>
                    </group>
                    <group string="Năm trước">
                        <field name="nam_chot_con_lai"/>
                        <field name="con_lai_nam_truoc"/>
                    </group>
                    <group string="Hạn mức phép có lương / tháng">
                        <field name="can_edit_monthly_paid_leave_cap" invisible="1"/>
                        <field
                            name="monthly_paid_leave_cap"
                            readonly="not can_edit_monthly_paid_leave_cap"
                            placeholder="Mặc định 3 ngày"
                        />
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
