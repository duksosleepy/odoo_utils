<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lug_device_list" model="ir.ui.view">
        <field name="name">lug.device.list</field>
        <field name="model">lug.device</field>
        <field name="arch" type="xml">
            <list string="Thiết bị" create="0" edit="0" delete="0" export_xlsx="1">
                <field name="user_id"/>
                <field name="device_name"/>
                <field name="serial_number" optional="show"/>
                <field name="mac_address" optional="hide"/>
                <field name="browser"/>
                <field name="os" optional="show"/>
                <field name="first_login"/>
                <field name="last_login"/>
                <field name="session_count"/>
            </list>
        </field>
    </record>

    <record id="view_lug_device_form" model="ir.ui.view">
        <field name="name">lug.device.form</field>
        <field name="model">lug.device</field>
        <field name="arch" type="xml">
            <form string="Thiết bị" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="device_name"/>
                            <field name="serial_number"/>
                            <field name="mac_address"/>
                        </group>
                        <group>
                            <field name="browser"/>
                            <field name="os"/>
                            <field name="first_login"/>
                            <field name="last_login"/>
                            <field name="session_count"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lug_device_search" model="ir.ui.view">
        <field name="name">lug.device.search</field>
        <field name="model">lug.device</field>
        <field name="arch" type="xml">
            <search string="Thiết bị">
                <field name="user_id"/>
                <field name="device_name"/>
                <field name="serial_number"/>
                <group>
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lug_device" model="ir.actions.act_window">
        <field name="name">Thiết bị</field>
        <field name="res_model">lug.device</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lug_device_search"/>
    </record>
</odoo>
