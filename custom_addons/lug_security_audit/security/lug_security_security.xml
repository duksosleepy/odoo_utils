<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="res.groups.privilege" id="res_groups_privilege_lug_security">
        <field name="name">Lug Security</field>
        <field name="category_id" ref="base.module_category_administration"/>
        <field name="sequence">96</field>
        <field name="placeholder">Không</field>
    </record>

    <record id="group_lug_security_user" model="res.groups">
        <field name="name">User</field>
        <field name="comment">Xem báo cáo và phiên đăng nhập Lug Security.</field>
        <field name="privilege_id" ref="res_groups_privilege_lug_security"/>
        <field name="implied_ids" eval="[(4, ref('base.group_allow_export'))]"/>
    </record>

    <record id="group_lug_security_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="comment">Quản trị toàn bộ Lug Security Audit.</field>
        <field name="privilege_id" ref="res_groups_privilege_lug_security"/>
        <field name="implied_ids" eval="[(4, ref('group_lug_security_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
