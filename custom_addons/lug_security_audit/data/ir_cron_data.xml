<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="ir_cron_lug_security_auto_offline" model="ir.cron">
        <field name="name">Lug Security: Auto Offline</field>
        <field name="model_id" ref="model_lug_user_session"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_offline()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_lug_security_daily_summary" model="ir.cron">
        <field name="name">Lug Security: Daily Summary</field>
        <field name="model_id" ref="model_lug_user_session"/>
        <field name="state">code</field>
        <field name="code">model._cron_daily_summary()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_lug_security_monthly_summary" model="ir.cron">
        <field name="name">Lug Security: Monthly Summary</field>
        <field name="model_id" ref="model_lug_user_session"/>
        <field name="state">code</field>
        <field name="code">model._cron_monthly_summary()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
