<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_leave_store_region_export_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.store.region.export.wizard.form</field>
        <field name="model">hr.leave.matrix.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Kết xuất nghỉ phép CH theo miền">
                <group>
                    <group>
                        <field name="year" invisible="1"/>
                        <field name="regional_date_filter" required="1"/>
                        <field name="regional_date_from" required="1"/>
                        <field name="regional_date_to" required="1"/>
                    </group>
                    <group>
                        <field name="regional_mien" required="1"/>
                        <field name="regional_employee_hrm_id"/>
                        <field name="regional_attendance_code"/>
                    </group>
                </group>
                <p class="text-muted">
                    Xuất đơn nghỉ phép cửa hàng theo miền và khoảng ngày. ID HRM và Mã máy chấm công có thể để trống.
                </p>
                <field name="domain_json" invisible="1"/>
                <footer>
                    <button name="action_export_store_by_region_excel" type="object" string="Export Excel" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
