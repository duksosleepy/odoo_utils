<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_leave_import_capnhatcong_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.import.capnhatcong.wizard.form</field>
        <field name="model">hr.leave.matrix.export.wizard</field>
        <field name="arch" type="xml">
            <form string="import_capnhatcong CUA HANG">
                <group>
                    <field name="year"/>
                    <field name="month"/>
                </group>
                <p class="text-muted">
                    Xuất file import cập nhật công cửa hàng (miền Bắc, Nam, ĐTT). Mỗi đơn nghỉ một dòng (Ngay_Bd → Ngay_Kt).
                </p>
                <field name="domain_json" invisible="1"/>
                <footer>
                    <button name="action_export_import_capnhatcong_ch_excel" type="object" string="Export Excel" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_hr_leave_import_capnhatcong_vp_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.import.capnhatcong.vp.wizard.form</field>
        <field name="model">hr.leave.matrix.export.wizard</field>
        <field name="arch" type="xml">
            <form string="import_capnhatcong VP">
                <group>
                    <field name="year"/>
                    <field name="month"/>
                </group>
                <p class="text-muted">
                    Xuất file import cập nhật công văn phòng (miền VP). Mỗi đơn nghỉ một dòng (Ngay_Bd → Ngay_Kt).
                </p>
                <field name="domain_json" invisible="1"/>
                <footer>
                    <button name="action_export_import_capnhatcong_vp_excel" type="object" string="Export Excel" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
