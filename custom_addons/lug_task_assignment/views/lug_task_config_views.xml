<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lug_task_category_list" model="ir.ui.view">
        <field name="name">lug.task.category.list</field>
        <field name="model">lug.task.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="point"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lug_task_priority_list" model="ir.ui.view">
        <field name="name">lug.task.priority.list</field>
        <field name="model">lug.task.priority</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="sla_hours"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lug_task_kpi_form" model="ir.ui.view">
        <field name="name">lug.task.kpi.monthly.form</field>
        <field name="model">lug.task.kpi.monthly</field>
        <field name="arch" type="xml">
            <form string="KPI tháng">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="year"/>
                            <field name="month"/>
                            <field name="score" readonly="1"/>
                            <field name="productivity" readonly="1"/>
                        </group>
                        <group>
                            <field name="planned_points"/>
                            <field name="completed_points"/>
                            <field name="total_tasks" readonly="1"/>
                            <field name="on_time_total" readonly="1"/>
                            <field name="defect_tasks" readonly="1"/>
                            <field name="total_hours" readonly="1"/>
                        </group>
                    </group>
                    <group string="Thành phần KPI">
                        <group>
                            <field name="volume_score" readonly="1"/>
                            <field name="on_time_score" readonly="1"/>
                            <field name="quality_score" readonly="1"/>
                        </group>
                        <group>
                            <field name="initiative_score"
                                   groups="lug_task_assignment.group_lug_task_manager"/>
                            <field name="process_score"
                                   groups="lug_task_assignment.group_lug_task_manager"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lug_task_kpi_list" model="ir.ui.view">
        <field name="name">lug.task.kpi.monthly.list</field>
        <field name="model">lug.task.kpi.monthly</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="year"/>
                <field name="month"/>
                <field name="score"/>
                <field name="productivity"/>
                <field name="total_tasks"/>
                <field name="on_time_total"/>
                <field name="defect_tasks"/>
            </list>
        </field>
    </record>

    <record id="action_lug_task_category" model="ir.actions.act_window">
        <field name="name">Loại công việc</field>
        <field name="res_model">lug.task.category</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_lug_task_priority" model="ir.actions.act_window">
        <field name="name">Mức độ / SLA</field>
        <field name="res_model">lug.task.priority</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_lug_task_kpi" model="ir.actions.act_window">
        <field name="name">KPI tháng</field>
        <field name="res_model">lug.task.kpi.monthly</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
