<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lug_task_list" model="ir.ui.view">
        <field name="name">lug.task.list</field>
        <field name="model">lug.task</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue" decoration-success="state in ('completed', 'closed')">
                <field name="task_code"/>
                <field name="title"/>
                <field name="assigned_to_id"/>
                <field name="priority_id"/>
                <field name="category_id"/>
                <field name="point"/>
                <field name="due_date"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-danger="state in ('overdue', 'escalation')"
                       decoration-warning="state == 'review'"
                       decoration-success="state in ('completed', 'closed')"/>
                <field name="is_overdue" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_lug_task_kanban" model="ir.ui.view">
        <field name="name">lug.task.kanban</field>
        <field name="model">lug.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="title"/>
                <field name="task_code"/>
                <field name="assigned_to_id"/>
                <field name="due_date"/>
                <field name="priority_id"/>
                <field name="is_overdue"/>
                <field name="progress"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="#{record.is_overdue.raw_value ? 'border border-danger' : ''}">
                            <strong t-esc="record.title.value"/>
                            <div class="text-muted small" t-esc="record.task_code.value"/>
                            <div class="mt-1">
                                <field name="assigned_to_id"/>
                            </div>
                            <div class="d-flex justify-content-between mt-2 small">
                                <span t-if="record.due_date.value" t-esc="record.due_date.value"/>
                                <span t-att-class="record.is_overdue.raw_value ? 'text-danger fw-bold' : ''">
                                    <t t-esc="record.progress.value"/>%
                                </span>
                            </div>
                            <field name="priority_id" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_lug_task_form" model="ir.ui.view">
        <field name="name">lug.task.form</field>
        <field name="model">lug.task</field>
        <field name="arch" type="xml">
            <form string="Công việc">
                <header>
                    <button name="action_submit_for_approval" string="Gửi phê duyệt" type="object"
                            invisible="state != 'draft'"
                            groups="lug_task_assignment.group_lug_task_team_lead"/>
                    <button name="action_approve" string="Phê duyệt" type="object"
                            invisible="state != 'draft'"
                            groups="lug_task_assignment.group_lug_task_manager"/>
                    <button name="action_assign" string="Giao việc" type="object"
                            invisible="state not in ('approved',)"
                            groups="lug_task_assignment.group_lug_task_team_lead"/>
                    <button name="action_accept" string="Nhận việc" type="object"
                            invisible="state != 'assigned'"/>
                    <button name="action_start" string="Bắt đầu" type="object"
                            invisible="state not in ('accepted', 'pending')"/>
                    <button name="action_pending" string="Tạm dừng" type="object"
                            invisible="state != 'in_progress'"/>
                    <button name="action_submit_review" string="Gửi duyệt kết quả" type="object"
                            invisible="state != 'in_progress'"/>
                    <button name="action_complete" string="Hoàn thành" type="object"
                            invisible="state != 'review'"
                            groups="lug_task_assignment.group_lug_task_manager,lug_task_assignment.group_lug_task_team_lead"/>
                    <button name="action_reject_review" string="Từ chối" type="object"
                            invisible="state != 'review'"
                            groups="lug_task_assignment.group_lug_task_manager,lug_task_assignment.group_lug_task_team_lead"/>
                    <button name="action_close" string="Đóng việc" type="object"
                            invisible="state != 'completed'"
                            groups="lug_task_assignment.group_lug_task_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved,assigned,accepted,in_progress,review,completed,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_attachments" type="object" class="oe_stat_button" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo" string="Tệp"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Quá hạn" bg_color="text-bg-danger" invisible="not is_overdue"/>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="Tiêu đề công việc..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="task_code" readonly="1"/>
                            <field name="parent_task_id"/>
                            <field name="category_id"/>
                            <field name="priority_id"/>
                            <field name="point"/>
                        </group>
                        <group>
                            <field name="assigned_by_id"/>
                            <field name="assigned_to_id"/>
                            <field name="reviewer_id"/>
                            <field name="approver_id"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="review_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="mien_zone_id" readonly="1"/>
                            <field name="store_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="due_date"/>
                            <field name="sla_deadline" readonly="1"/>
                            <field name="completed_date" readonly="1"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="checklist_progress" readonly="1"/>
                            <field name="estimate_hours"/>
                            <field name="actual_hours" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                            <field name="is_quality_issue"/>
                            <field name="process_compliant"/>
                            <field name="rejection_reason" invisible="state != 'review'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả">
                            <field name="description"/>
                        </page>
                        <page string="Checklist">
                            <field name="checklist_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="completed"/>
                                </list>
                            </field>
                        </page>
                        <page string="Timesheet">
                            <field name="timesheet_ids">
                                <list editable="bottom">
                                    <field name="work_date"/>
                                    <field name="employee_id"/>
                                    <field name="hours"/>
                                </list>
                            </field>
                        </page>
                        <page string="Bình luận">
                            <field name="comment_ids">
                                <list>
                                    <field name="create_date"/>
                                    <field name="employee_id"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                        <page string="Lịch sử">
                            <field name="history_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="action"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                    <field name="created_by_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lug_task_search" model="ir.ui.view">
        <field name="name">lug.task.search</field>
        <field name="model">lug.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <field name="task_code"/>
                <field name="assigned_to_id"/>
                <field name="assigned_by_id"/>
                <filter string="Việc của tôi" name="my_tasks"
                        domain="[('assigned_to_id.user_id', '=', uid)]"/>
                <filter string="Chờ duyệt" name="pending_review" domain="[('state', '=', 'review')]"/>
                <filter string="Quá hạn" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <filter string="Sắp đến hạn" name="due_soon"
                        domain="[('due_date', '!=', False), ('state', 'not in', ('closed', 'completed'))]"/>
                <group>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Người nhận" name="group_assignee" context="{'group_by': 'assigned_to_id'}"/>
                    <filter string="Phòng ban" name="group_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Miền" name="group_mien" context="{'group_by': 'mien_zone_id'}"/>
                    <filter string="Chi nhánh" name="group_store" context="{'group_by': 'store_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lug_task" model="ir.actions.act_window">
        <field name="name">Công việc</field>
        <field name="res_model">lug.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_my_tasks': 1}</field>
    </record>
</odoo>
