<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_leave_analytics.LeaveAnalyticsDashboard">
        <div class="o_leave_analytics_dashboard o_action">
            <div class="o_leave_analytics_header">
                <h1>Báo cáo tổng — Nghỉ phép</h1>
                <p class="text-muted mb-0">Dashboard tổng quan cho HR và Ban Giám đốc (Sáng Tâm)</p>
            </div>

            <div class="o_leave_analytics_filters card mb-3">
                <div class="card-body d-flex flex-wrap gap-3 align-items-end">
                    <div>
                        <label class="form-label">Từ ngày</label>
                        <DateTimeInput
                            type="'date'"
                            value="state.filters.date_from"
                            onChange="(date) => this.onDateFromChange(date)"
                        />
                    </div>
                    <div>
                        <label class="form-label">Đến ngày</label>
                        <DateTimeInput
                            type="'date'"
                            value="state.filters.date_to"
                            onChange="(date) => this.onDateToChange(date)"
                        />
                    </div>
                    <div>
                        <label class="form-label">Miền</label>
                        <select class="form-select" t-on-change="onMienChange">
                            <t t-foreach="mienOptions" t-as="option" t-key="option.value || 'all'">
                                <option t-att-value="option.value || ''" t-att-selected="state.filters.employee_mien === option.value ? 'selected' : None" t-esc="option.label"/>
                            </t>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Khối</label>
                        <select class="form-select" t-on-change="onWorkforceChange">
                            <t t-foreach="workforceOptions" t-as="option" t-key="option.value || 'all'">
                                <option t-att-value="option.value || ''" t-att-selected="state.filters.workforce_block === option.value ? 'selected' : None" t-esc="option.label"/>
                            </t>
                        </select>
                    </div>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="text-center p-5">
                    <i class="fa fa-spinner fa-spin fa-2x"/>
                </div>
            </t>

            <t t-elif="state.data">
                <div class="o_leave_analytics_kpis row g-3 mb-4">
                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="o_kpi_card card h-100" t-on-click="() => this.drillDown('approved_period')">
                            <div class="card-body">
                                <div class="o_kpi_value" t-esc="state.data.kpis.total_employees"/>
                                <div class="o_kpi_label">Tổng NV đang làm việc</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="o_kpi_card card h-100" t-on-click="() => this.drillDown('leave_today')">
                            <div class="card-body">
                                <div class="o_kpi_value" t-esc="state.data.kpis.leave_today"/>
                                <div class="o_kpi_label">Nghỉ phép hôm nay</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="o_kpi_card card h-100" t-on-click="() => this.drillDown('approved_period')">
                            <div class="card-body">
                                <div class="o_kpi_value" t-esc="state.data.kpis.leave_month"/>
                                <div class="o_kpi_label">Nghỉ phép tháng này</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="o_kpi_card card h-100" t-on-click="() => this.drillDown('to_approve')">
                            <div class="card-body">
                                <div class="o_kpi_value text-warning" t-esc="state.data.kpis.to_approve"/>
                                <div class="o_kpi_label">Đang chờ duyệt</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="o_kpi_card card h-100">
                            <div class="card-body">
                                <div class="o_kpi_value" t-esc="formatPercent(state.data.kpis.leave_rate)"/>
                                <div class="o_kpi_label">Tỷ lệ nghỉ phép</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <div class="o_kpi_card card h-100" t-on-click="() => this.drillDown('employee', state.data.kpis.top_leave_employee.id)">
                            <div class="card-body">
                                <div class="o_kpi_value small" t-esc="state.data.kpis.top_leave_employee.label"/>
                                <div class="o_kpi_label">NV nghỉ nhiều nhất (<t t-esc="state.data.kpis.top_leave_employee.value"/> ngày)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header">Nghỉ phép theo loại</div>
                            <div class="card-body">
                                <div class="o_chart_pie" t-att-style="pieStyle(state.data.charts.by_type)"/>
                                <div class="o_chart_legend mt-3">
                                    <t t-foreach="state.data.charts.by_type" t-as="item" t-key="item.label">
                                        <div class="o_legend_row cursor-pointer" t-on-click="() => this.drillDownChart('by_type', item)">
                                            <span t-esc="item.label"/>
                                            <strong t-esc="item.value"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header">Nghỉ phép theo khối (Văn phòng / Cửa hàng)</div>
                            <div class="card-body">
                                <div class="o_chart_pie" t-att-style="pieStyle(state.data.charts.by_workforce)"/>
                                <div class="o_chart_legend mt-3">
                                    <t t-foreach="state.data.charts.by_workforce" t-as="item" t-key="item.label">
                                        <div class="o_legend_row">
                                            <span t-esc="item.label"/>
                                            <strong t-esc="item.value"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header">Nghỉ phép theo phòng ban</div>
                            <div class="card-body">
                                <t t-foreach="state.data.charts.by_department" t-as="item" t-key="item.label">
                                    <div class="o_bar_row cursor-pointer" t-on-click="() => this.drillDownChart('by_department', item)">
                                        <div class="o_bar_label" t-esc="item.label"/>
                                        <div class="o_bar_track">
                                            <div class="o_bar_fill" t-att-style="'width: ' + barWidth(item.value, state.data.charts.by_department)"/>
                                        </div>
                                        <div class="o_bar_value" t-esc="item.value"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-header">Nghỉ phép theo miền</div>
                            <div class="card-body">
                                <t t-foreach="state.data.charts.by_mien" t-as="item" t-key="item.label">
                                    <div class="o_bar_row cursor-pointer" t-on-click="() => this.drillDownChart('by_mien', item)">
                                        <div class="o_bar_label" t-esc="item.label"/>
                                        <div class="o_bar_track">
                                            <div class="o_bar_fill o_bar_fill_mien" t-att-style="'width: ' + barWidth(item.value, state.data.charts.by_mien)"/>
                                        </div>
                                        <div class="o_bar_value" t-esc="item.value"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-lg-8">
                        <div class="card h-100">
                            <div class="card-header">Xu hướng nghỉ phép theo tháng</div>
                            <div class="card-body">
                                <t t-foreach="state.data.charts.by_month" t-as="item" t-key="item.label">
                                    <div class="o_bar_row">
                                        <div class="o_bar_label" t-esc="item.label"/>
                                        <div class="o_bar_track">
                                            <div class="o_bar_fill o_bar_fill_trend" t-att-style="'width: ' + barWidth(item.value, state.data.charts.by_month)"/>
                                        </div>
                                        <div class="o_bar_value" t-esc="item.value"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card h-100">
                            <div class="card-header">Heatmap theo thứ</div>
                            <div class="card-body">
                                <t t-foreach="state.data.charts.by_weekday" t-as="item" t-key="item.label">
                                    <div class="o_bar_row">
                                        <div class="o_bar_label" t-esc="item.label"/>
                                        <div class="o_bar_track">
                                            <div class="o_bar_fill o_bar_fill_heat" t-att-style="'width: ' + barWidth(item.value, state.data.charts.by_weekday)"/>
                                        </div>
                                        <div class="o_bar_value" t-esc="item.value"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-lg-12">
                        <div class="card">
                            <div class="card-header">Top 10 cửa hàng nghỉ nhiều nhất</div>
                            <div class="card-body">
                                <t t-foreach="state.data.charts.by_store" t-as="item" t-key="item.label">
                                    <div class="o_bar_row cursor-pointer" t-on-click="() => this.drillDownChart('by_store', item)">
                                        <div class="o_bar_label" t-esc="item.label"/>
                                        <div class="o_bar_track">
                                            <div class="o_bar_fill o_bar_fill_store" t-att-style="'width: ' + barWidth(item.value, state.data.charts.by_store)"/>
                                        </div>
                                        <div class="o_bar_value" t-esc="item.value"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-lg-4">
                        <div class="card h-100">
                            <div class="card-header">Top nhân viên nghỉ nhiều</div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead><tr><th>Nhân viên</th><th class="text-end">Ngày nghỉ</th></tr></thead>
                                    <tbody>
                                        <t t-foreach="state.data.alerts.top_employees" t-as="item" t-key="item.id">
                                            <tr class="cursor-pointer" t-on-click="() => this.drillDown('employee', item.id)">
                                                <td t-esc="item.label"/>
                                                <td class="text-end" t-esc="item.value"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card h-100">
                            <div class="card-header">Sắp hết phép năm</div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead><tr><th>Nhân viên</th><th class="text-end">Còn lại</th></tr></thead>
                                    <tbody>
                                        <t t-foreach="state.data.alerts.low_balance" t-as="item" t-key="item.id">
                                            <tr>
                                                <td t-esc="item.label"/>
                                                <td class="text-end text-danger" t-esc="item.value"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card h-100">
                            <div class="card-header">Chưa sử dụng phép</div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead><tr><th>Nhân viên</th><th class="text-end">Còn lại</th></tr></thead>
                                    <tbody>
                                        <t t-foreach="state.data.alerts.unused_leave" t-as="item" t-key="item.id">
                                            <tr>
                                                <td t-esc="item.label"/>
                                                <td class="text-end" t-esc="item.value"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
